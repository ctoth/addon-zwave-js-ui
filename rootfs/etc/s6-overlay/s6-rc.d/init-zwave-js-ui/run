#!/command/with-contenv bashio
# First-run: generate settings.json with MQTT creds from Supervisor
declare device
declare gateway
declare host="core-mosquitto"
declare mqtt
declare password=""
declare port="1883"
declare username=""
declare zwave

mkdir -p /data/db

# Only generate settings on first run; user edits via UI after that
if bashio::fs.directory_exists "/data/store"; then
  bashio::exit.ok
fi

mkdir -p /data/store || bashio::exit.nok "Could not create data store."

# Read add-on options
device=""
if bashio::config.has_value "device"; then
  device=$(bashio::config "device")
fi

# Auto-discover MQTT from Supervisor
if bashio::services.available "mqtt"; then
  host=$(bashio::services "mqtt" "host")
  password=$(bashio::services "mqtt" "password")
  port=$(bashio::services "mqtt" "port")
  username=$(bashio::services "mqtt" "username")
  bashio::log.info "MQTT broker discovered at ${host}:${port}"
fi

# Gateway config — MQTT gateway mode ENABLED by default
gateway=$(bashio::var.json \
  "payloadType" "^0" \
  "type" "^0" \
  hassDiscovery "^true" \
  logEnabled "^true" \
  logLevel "$(bashio::config 'log_level')" \
  logToFile "^false" \
  nodeNames "^true" \
)

# MQTT config — ENABLED by default (disabled=false)
mqtt=$(bashio::var.json \
  auth "^true" \
  disabled "^false" \
  host "${host}" \
  name "Mosquitto" \
  password "${password}" \
  port "^${port}" \
  username "${username}" \
)

# Z-Wave config
zwave=$(bashio::var.json \
  commandsTimeout "^30" \
  logLevel "$(bashio::config 'log_level')" \
  logToFile "^false" \
  networkKey "$(bashio::config 'network_key')" \
  port "${device}" \
  serverEnabled "^true" \
  serverPort "^3000" \
)

bashio::var.json \
  gateway "^${gateway}" \
  mqtt "^${mqtt}" \
  zwave "^${zwave}" \
  > /data/store/settings.json

bashio::log.info "Generated initial settings.json (MQTT gateway enabled)"
